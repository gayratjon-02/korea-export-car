# ==========================================
# Korea Car Import — Environment Variables
# ==========================================

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/korea_car_import?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# AWS S3
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="korea-car-import"

# Redis
REDIS_URL="redis://localhost:6379"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Server
PORT=4000
NODE_ENV=development

# AI (Batch service)
ANTHROPIC_API_KEY=""
